---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
};

const { title, description, canonicalPath = Astro.url.pathname } = Astro.props;
const siteUrl = 'https://spielzeugkompass-ratgeber.pages.dev';
const canonical = new URL(canonicalPath, siteUrl).toString();
const pageTitle = title.includes('SpielzeugKompass') ? title : `${title} | SpielzeugKompass`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SpielzeugKompass',
  url: siteUrl,
  inLanguage: 'de-DE',
  description
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="yPpe7RqFmJlFWGW8pmTMccb6P9_85pKfoSRyazRjG6g" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/icon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SpielzeugKompass" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <div class="site-shell">
      <Header />
      <main id="inhalt" class="site-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
